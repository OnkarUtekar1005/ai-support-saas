generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant Organization ───
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  tickets          Ticket[]
  systemConfigs    SystemConfig[]
  dbConnections    DatabaseConnection[]
  errorLogs        ErrorLog[]
  knowledgeEntries KnowledgeEntry[]
  emailSettings    EmailSettings?
  invoiceSettings  InvoiceSettings?

  // CRM
  projects         Project[]
  contacts         Contact[]
  companies        Company[]
  activities       Activity[]
  invoices         Invoice[]

  // Integrations
  apiKeys          ApiKey[]
  sdkEvents        SdkEvent[]

  // Auto-Fix Pipeline
  pipelines        Pipeline[]
  vpsAgents        VpsAgent[]

  // Agents
  projectDocuments      ProjectDocument[]
  functionalResolutions FunctionalResolution[]
  notifications         Notification[]
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ─── Users & Auth ───
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  role           Role     @default(AGENT)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        Ticket[]       @relation("ticketCreator")
  assignedTickets Ticket[]      @relation("ticketAssignee")
  chatSessions   ChatSession[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]

  // CRM
  assignedActivities Activity[] @relation("activityAssignee")
  createdActivities  Activity[] @relation("activityCreator")
  projectMembers   ProjectMember[]
  projectCosts     ProjectCost[]    @relation("costAddedBy")
  projectAttachments ProjectAttachment[] @relation("attachmentUploadedBy")
  projectUpdates   ProjectUpdate[]  @relation("updateCreatedBy")
  createdInvoices  Invoice[]        @relation("invoiceCreatedBy")
  joinRequests        ProjectJoinRequest[] @relation("joinRequestUser")
  resolvedJoinRequests ProjectJoinRequest[] @relation("joinRequestResolver")
}

// ─── Refresh Tokens ───
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

// ─── Support Tickets ───
model Ticket {
  id             String        @id @default(uuid())
  title          String
  description    String        @db.Text
  status         TicketStatus  @default(OPEN)
  priority       Priority      @default(MEDIUM)
  issueType      String?
  issueCategory  IssueCategory @default(UNKNOWN)
  confidence     Float?
  analysis       Json?
  resolution     String?       @db.Text
  projectId      String?
  organizationId String
  createdById    String
  contactId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  assigneeId     String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("ticketCreator", fields: [createdById], references: [id])
  assignee     User?         @relation("ticketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  chatSessions ChatSession[]
  attachments  Attachment[]

  @@index([assigneeId])
}

enum IssueCategory {
  TECHNICAL
  FUNCTIONAL
  UNKNOWN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLARIFICATION
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Chat Sessions ───
model ChatSession {
  id        String   @id @default(uuid())
  ticketId  String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket   Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id            String   @id @default(uuid())
  chatSessionId String
  role          String   // 'user' | 'assistant' | 'system'
  content       String   @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

// ─── Attachments ───
model Attachment {
  id        String   @id @default(uuid())
  ticketId  String
  fileName  String
  fileType  String
  filePath  String
  fileSize  Int
  parsed    String?  @db.Text
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── Database Connections (per org) ───
model DatabaseConnection {
  id             String   @id @default(uuid())
  name           String
  host           String
  port           Int      @default(1433)
  database       String
  username       String
  passwordEnc    String   // encrypted
  dbType         String   @default("mssql")
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── System Configurations ───
model SystemConfig {
  id             String   @id @default(uuid())
  name           String
  description    String?
  config         Json     // Full SystemConfig JSON
  isDefault      Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Knowledge Base (RAG) ───
model KnowledgeEntry {
  id             String   @id @default(uuid())
  title          String
  content        String   @db.Text
  category       String?
  embedding      Float[]  // vector embedding — upgrade to pgvector(768) when extension is installed
  projectId      String?  // project-scoped entries
  documentId     String?  // source document
  chunkIndex     Int?     // position within document
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  document     ProjectDocument?  @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
}

// ─── Error Logs (with Gemini Analysis) ───
model ErrorLog {
  id              String        @id @default(uuid())
  level           ErrorLevel
  message         String        @db.Text
  stack           String?       @db.Text
  source          String        // module/service name
  category        String?       // database, api, auth, cors, timeout, code, network, email, memory, frontend, disk, validation
  endpoint        String?       // API endpoint if applicable
  userId          String?       // user who triggered it
  projectId       String?       // linked project/system
  requestData     Json?         // sanitized request data
  aiAnalysis      String?       @db.Text  // Gemini's root cause analysis
  aiSuggestion    String?       @db.Text  // Gemini's fix suggestion
  analyzed        Boolean       @default(false)
  emailSent       Boolean       @default(false)
  fingerprint     String?       // stable hash for dedup + regression detection
  language        String?       // javascript, python, java, go, ruby, etc.
  framework       String?       // express, django, spring-boot, etc.
  environment     String?       // production, staging, development
  hostname        String?       // machine hostname
  metadata        Json?         // generic key-value extra context
  occurrenceCount Int           @default(1)
  lastSeenAt      DateTime      @default(now())
  organizationId  String
  createdAt       DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, lastSeenAt])
  @@index([level])
  @@index([analyzed])
  @@index([projectId])
  @@index([category])
  @@index([fingerprint])
}

enum ErrorLevel {
  INFO
  WARN
  ERROR
  FATAL
}

// ─── Invoice / Branding Settings (per org) ───
model InvoiceSettings {
  id              String   @id @default(uuid())
  organizationId  String   @unique
  companyName     String?
  companyAddress  String?  @db.Text
  companyPhone    String?
  companyEmail    String?
  companyWebsite  String?
  logoUrl         String?
  primaryColor    String   @default("#1e40af")
  accentColor     String   @default("#dbeafe")
  footerText      String   @default("Thank you for your business!")
  paymentTerms    String   @default("Payment due within 30 days")
  bankDetails     String?  @db.Text
  taxId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Email Settings (per org) ───
model EmailSettings {
  id             String   @id @default(uuid())
  smtpHost       String
  smtpPort       Int      @default(587)
  smtpUser       String
  smtpPassEnc    String   // encrypted
  adminEmails    String[] // list of admin emails to notify
  notifyOnError  Boolean  @default(true)
  notifyOnFatal  Boolean  @default(true)
  digestEnabled  Boolean  @default(false)
  digestCron     String?  @default("0 9 * * *") // daily at 9am
  organizationId String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════
// ─── CRM MODULE ───
// ═══════════════════════════════════════════

// ─── Projects (multi-project support) ───
model Project {
  id              String        @id @default(uuid())
  name            String
  description     String?       @db.Text
  status          ProjectStatus @default(ACTIVE)
  color           String        @default("#3b82f6")
  totalBudget     Float?
  currency        String        @default("USD")
  deadline        DateTime?
  clientContactId String?
  organizationId  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientContact  Contact?        @relation("ProjectClientContact", fields: [clientContactId], references: [id], onDelete: SetNull)
  members        ProjectMember[]
  contacts       Contact[]
  companies      Company[]
  activities     Activity[]
  tickets        Ticket[]
  apiKeys        ApiKey[]
  chatbotConfig  ChatbotConfig?
  errorLogs      ErrorLog[]
  pipelines      Pipeline[]
  vpsAgents      VpsAgent[]
  autoFixConfig  AutoFixConfig?
  knowledgeEntries      KnowledgeEntry[]
  documents             ProjectDocument[]
  functionalResolutions FunctionalResolution[]
  functionalAgentConfig FunctionalAgentConfig?
  reminderConfig        ReminderConfig?
  costs                 ProjectCost[]
  projectAttachments    ProjectAttachment[]
  updates               ProjectUpdate[]
  invoices              Invoice[]
  joinRequests          ProjectJoinRequest[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ─── Project Members ───
model ProjectMember {
  id        String            @id @default(uuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  MEMBER
}

// ─── Project Join Requests ───
enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProjectJoinRequest {
  id           String            @id @default(uuid())
  projectId    String
  userId       String
  status       JoinRequestStatus @default(PENDING)
  message      String?
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User    @relation("joinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("joinRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([status])
}

// ─── Companies / Accounts ───
model Company {
  id             String   @id @default(uuid())
  name           String
  domain         String?
  industry       String?
  size           String?
  phone          String?
  address        String?  @db.Text
  notes          String?  @db.Text
  projectId      String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contacts     Contact[]
  activities   Activity[]

  @@index([organizationId])
  @@index([projectId])
}

// ─── Contacts ───
model Contact {
  id             String        @id @default(uuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  jobTitle       String?
  status         ContactStatus @default(ACTIVE)
  source         String?
  notes          String?       @db.Text
  companyId      String?
  projectId      String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientProjects Project[]    @relation("ProjectClientContact")
  activities     Activity[]
  tickets        Ticket[]
  invoices       Invoice[]

  @@index([organizationId])
  @@index([projectId])
  @@index([companyId])
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  LEAD
  CUSTOMER
  CHURNED
}

// ─── Activities / Tasks ───
model Activity {
  id             String         @id @default(uuid())
  type           ActivityType
  subject        String
  description    String?        @db.Text
  status         ActivityStatus @default(TODO)
  dueDate        DateTime?
  completedAt    DateTime?
  contactId      String?
  companyId      String?
  assigneeId     String?
  createdById    String
  projectId      String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee     User?        @relation("activityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("activityCreator", fields: [createdById], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([dueDate])
}

// ═══════════════════════════════════════════
// ─── PROJECT FINANCE MODULE ───
// ═══════════════════════════════════════════

enum CostType {
  BASE_COST
  EXTRA_FEATURE
  EXPENSE
  PAYMENT_RECEIVED
}

model ProjectCost {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  description String?   @db.Text
  type        CostType  @default(BASE_COST)
  amount      Float
  date        DateTime  @default(now())
  notes       String?   @db.Text
  addedById   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy   User?   @relation("costAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model ProjectAttachment {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  fileType     String
  filePath     String
  fileSize     Int?
  notes        String?  @db.Text
  uploadedById String?
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("attachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model ProjectUpdate {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  content     String   @db.Text
  sentEmails  String[]
  emailSent   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("updateCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
}

enum InvoiceType {
  INVOICE
  PURCHASE_ORDER
  WORK_ORDER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String
  projectId      String
  organizationId String
  type           InvoiceType   @default(INVOICE)
  status         InvoiceStatus @default(DRAFT)
  currency       String        @default("USD")
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  total          Float         @default(0)
  lineItems      Json          @default("[]")
  notes          String?       @db.Text
  billingName    String?
  billingEmail   String?
  billingAddress String?       @db.Text
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  contactId      String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("invoiceCreatedBy", fields: [createdById], references: [id])

  @@unique([invoiceNumber, organizationId])
  @@index([projectId])
  @@index([organizationId])
  @@index([status])
  @@index([type])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
  FOLLOW_UP
}

enum ActivityStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// ═══════════════════════════════════════════
// ─── INTEGRATIONS / SDK ───
// ═══════════════════════════════════════════

// ─── API Keys (for external app connections) ───
model ApiKey {
  id             String    @id @default(uuid())
  name           String    // "Production Website", "Mobile App iOS", etc.
  key            String    @unique // sk_live_xxxx or sk_test_xxxx
  platform       String    @default("web") // web, ios, android, server
  projectId      String?   // scope to a specific project (optional)
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  usageCount     Int       @default(0)
  allowedOrigins String[]  // CORS: ["https://myapp.com", "http://localhost:3000"]
  permissions    String[]  // ["contacts", "tickets", "errors", "events"]
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sdkEvents    SdkEvent[]

  @@index([key])
  @@index([organizationId])
}

// ─── SDK Events (tracked from external apps) ───
model SdkEvent {
  id             String   @id @default(uuid())
  type           String   // "page_view", "error", "contact.identify", "ticket.create", "custom"
  name           String?  // custom event name
  data           Json?    // event payload
  sessionId      String?  // browser/app session
  userId         String?  // external user ID from the app
  userEmail      String?  // external user email
  userAgent      String?
  ipAddress      String?
  pageUrl        String?
  apiKeyId       String
  organizationId String
  createdAt      DateTime @default(now())

  apiKey       ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([apiKeyId])
  @@index([type])
  @@index([userEmail])
}

// ═══════════════════════════════════════════
// ─── EMBEDDABLE CHATBOT ───
// ═══════════════════════════════════════════

// ─── Chatbot Configuration (per project, managed by admin) ───
model ChatbotConfig {
  id               String   @id @default(uuid())
  projectId        String   @unique
  botName          String   @default("AI Support")
  welcomeMessage   String   @default("Hi! How can I help you today?")
  systemPrompt     String   @db.Text // The AI personality/instructions
  placeholderText  String   @default("Type your message...")
  // Theme
  primaryColor     String   @default("#3b82f6")
  position         String   @default("bottom-right") // bottom-right, bottom-left
  avatarUrl        String?
  // Features
  enableChat       Boolean  @default(true)
  enableTickets    Boolean  @default(true)
  enableFileUpload Boolean  @default(false)
  // Behavior
  requireEmail     Boolean  @default(false) // ask for email before chat
  autoReply        Boolean  @default(true)  // AI auto-responds
  offlineMessage   String?  @default("We're offline right now. Leave a message and we'll get back to you.")
  // Context
  knowledgeContext String?  @db.Text // extra context fed to AI (FAQs, product info)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  widgetSessions WidgetSession[]
}

// ─── Widget Chat Sessions (end-user conversations) ───
model WidgetSession {
  id              String   @id @default(uuid())
  chatbotConfigId String
  visitorEmail    String?
  visitorName     String?
  visitorId       String?  // browser fingerprint / cookie ID
  userAgent       String?
  ipAddress       String?
  pageUrl         String?
  status          String   @default("active") // active, closed, archived
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chatbotConfig ChatbotConfig  @relation(fields: [chatbotConfigId], references: [id], onDelete: Cascade)
  messages      WidgetMessage[]

  @@index([chatbotConfigId])
  @@index([visitorEmail])
}

// ─── Widget Messages ───
model WidgetMessage {
  id              String   @id @default(uuid())
  widgetSessionId String
  role            String   // 'user' | 'assistant' | 'system'
  content         String   @db.Text
  createdAt       DateTime @default(now())

  widgetSession WidgetSession @relation(fields: [widgetSessionId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════
// ─── AUTO-FIX PIPELINE ───
// ═══════════════════════════════════════════

// ─── VPS Agent (registered VPS instances) ───
model VpsAgent {
  id               String   @id @default(uuid())
  name             String   // "Production Server", "Staging Server"
  host             String   // hostname or IP
  agentKey         String   @unique // secret key for agent auth
  projectPath      String   // /home/deploy/myapp — where code lives on VPS
  gitBranch        String   @default("main") // default branch
  buildCommand     String   @default("npm run build")
  restartCommand   String   @default("pm2 restart all")
  isOnline         Boolean  @default(false)
  lastHeartbeat    DateTime?
  projectId        String?  // linked project
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  pipelines    Pipeline[]

  @@index([organizationId])
  @@index([agentKey])
}

// ─── Pipeline (auto-fix workflow) ───
model Pipeline {
  id               String         @id @default(uuid())
  status           PipelineStatus @default(DETECTED)
  // Source
  errorLogId       String?        // the error that triggered this
  errorMessage     String         @db.Text
  errorSource      String
  errorStack       String?        @db.Text
  // Gemini analysis
  geminiAnalysis   String?        @db.Text
  geminiSuggestion String?        @db.Text
  // Claude Code
  claudePrompt     String?        @db.Text  // prompt sent to claude CLI
  claudeOutput     String?        @db.Text  // full claude CLI output
  claudeFixSummary String?        @db.Text  // summary of what claude changed
  filesChanged     String[]       // list of files modified
  // Git
  branchName       String?        // fix/error-abc123
  commitHash       String?
  prUrl            String?        // pull request URL if created
  // Deploy
  deployLog        String?        @db.Text
  deployedAt       DateTime?
  // Approval
  approvedBy       String?        // user ID who approved
  approvedAt       DateTime?
  rejectedReason   String?
  // Orchestrator fields
  autoTriggered      Boolean      @default(false)
  worktreePath       String?
  priority           Int          @default(0)
  claudeSessionId    String?      // for --resume between analysis and fix
  testOutput         String?      @db.Text
  isRegression       Boolean      @default(false)
  previousPipelineId String?      // link to the fix that didn't hold
  // Links
  vpsAgentId       String?
  projectId        String?
  organizationId   String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vpsAgent     VpsAgent?    @relation(fields: [vpsAgentId], references: [id], onDelete: SetNull)
  logs         PipelineLog[]

  @@index([organizationId])
  @@index([status])
  @@index([projectId])
}

enum PipelineStatus {
  DETECTED
  QUEUED
  QUEUED_CONFLICT
  ANALYZING
  FIX_PROPOSED
  AWAITING_APPROVAL
  APPROVED
  FIXING
  TESTING
  TEST_FAILED
  COMMITTED
  PR_CREATED
  DEPLOYING
  DEPLOYED
  FAILED
  REJECTED
  REGRESSION
}

// ─── Pipeline Activity Log ───
model PipelineLog {
  id         String   @id @default(uuid())
  pipelineId String
  stage      String
  message    String   @db.Text
  data       Json?
  createdAt  DateTime @default(now())

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

// ─── Auto-Fix Orchestrator Config (per project) ───
model AutoFixConfig {
  id                  String   @id @default(uuid())
  projectId           String   @unique
  enabled             Boolean  @default(false)
  autoTriggerLevel    String   @default("high")   // min Gemini severity: low, medium, high, critical
  maxConcurrent       Int      @default(2)
  cooldownMinutes     Int      @default(30)
  gitProvider         String   @default("github")  // github, gitlab, bitbucket
  gitTokenEnc         String?                       // encrypted PAT for PR creation
  gitRepoUrl          String?                       // https://github.com/user/repo
  targetBranch        String   @default("main")
  testCommand         String   @default("npm test")
  createPR            Boolean  @default(true)
  autoDeployOnApprove Boolean  @default(false)
  projectPath         String?                       // where code lives on VPS
  // Tech stack (generic — supports any language/framework)
  language            String?  // auto-detected if blank — supports any language
  framework           String?                         // express, django, spring-boot, gin, rails, laravel, etc.
  buildCommand        String   @default("npm run build")
  installCommand      String?                         // npm install, pip install -r requirements.txt, mvn install
  startCommand        String?                         // npm start, python manage.py runserver
  restartCommand      String?                         // pm2 restart all, systemctl restart app
  entryPoint          String?                         // src/index.ts, app/main.py, src/Main.java
  sourceDir           String?                         // src/, app/, cmd/
  testDir             String?                         // tests/, test/, __tests__/
  customPromptPrefix  String?  @db.Text               // extra context added to every Claude prompt
  excludePaths        String[]                        // never modify: ["migrations/", "vendor/"]

  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ═══════════════════════════════════════════
// ─── FUNCTIONAL AGENT ───
// ═══════════════════════════════════════════

// ─── Functional Agent Config (per project) ───
model FunctionalAgentConfig {
  id                   String   @id @default(uuid())
  projectId            String   @unique
  enabled              Boolean  @default(false)
  systemPrompt         String?  @db.Text   // custom instructions for this project's domain
  confidenceThreshold  Float    @default(0.7)
  autoResolveTickets   Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Project Documents (uploaded knowledge base files) ───
model ProjectDocument {
  id             String   @id @default(uuid())
  projectId      String
  organizationId String
  fileName       String
  fileType       String   // pdf, docx, txt, md
  filePath       String   // stored file path
  fileSize       Int
  status         String   @default("pending") // pending, processing, indexed, failed
  chunkCount     Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeEntries KnowledgeEntry[]

  @@index([projectId])
}

// ─── Functional Resolutions (agent-generated answers) ───
model FunctionalResolution {
  id               String   @id @default(uuid())
  ticketId         String?
  errorLogId       String?
  projectId        String
  organizationId   String
  query            String   @db.Text        // the original issue description
  rootCause        String   @db.Text        // why the issue occurred
  stepsAnalysis    String?  @db.Text        // what user did wrong vs correct steps
  solution         String   @db.Text        // step-by-step resolution
  knowledgeSources Json?                    // which KB entries were used [{id, title, score}]
  confidence       Float    @default(0)
  feedback         String?                  // helpful / not_helpful
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([ticketId])
}

// ═══════════════════════════════════════════
// ─── NOTIFICATIONS & REMINDERS ───
// ═══════════════════════════════════════════

model Notification {
  id             String   @id @default(uuid())
  userId         String
  type           String   // TASK_ASSIGNED, STATUS_UPDATE, REMINDER, PR_REVIEW, ERROR_ALERT
  title          String
  message        String   @db.Text
  link           String?
  read           Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([organizationId])
}

model ReminderConfig {
  id                String   @id @default(uuid())
  projectId         String   @unique
  enabled           Boolean  @default(false)
  overdueReminder   Boolean  @default(true)
  dueSoonHours      Int      @default(24)
  statusUpdateFreq  String   @default("daily") // daily, weekly, none
  assignOnCreate    Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
